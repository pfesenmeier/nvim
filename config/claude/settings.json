{
  "env": {
    "EDITOR": "nvim"
  },
  "permissions": {
    "allow": [
      "Bash(fd:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(xargs:*)",
      "Bash(cat:*)",
      "Bash(jj diff:*)",
      "Bash(jj show:*)",
      "Bash(jj log:*)",
      "Bash(jj help:*)",
      "Bash(git status:*)",
      "Bash(ls:*)",
      "Bash(stat:*)",
      "Bash(mkdir:*)",
      "Bash(dotnet build:*)",
      "Bash(dotnet test:*)",
      "Bash(curl -s -X POST http://localhost:5049/graphql:*)"
    ]
  },
  "model": "sonnet",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/prog-claude 1 25",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/prog-claude 1 100",
            "timeout": 5
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/prog-claude 2",
            "timeout": 5
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt|agent_needs_input",
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/prog-claude 4",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.local/bin/prog-claude 0",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "lua-lsp@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true
  },
  "effortLevel": "high",
  "autoUpdatesChannel": "stable",
  "tui": "fullscreen",
  "theme": "auto",
  "skipAutoPermissionPrompt": true
}
