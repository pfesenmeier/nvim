.shell powershell

# Reload whkd configuration
# alt + o                 : taskkill /f /im whkd.exe && start /b whkd # if shell is cmd
alt + o                 : taskkill /f /im whkd.exe; Start-Process whkd -WindowStyle hidden # if shell is pwsh / powershell
alt + shift + o         : komorebic reload-configuration

# App shortcuts - these require shell to be pwsh / powershell
# The apps will be focused if open, or launched if not open
# alt + shift + return    : if ($wshell.AppActivate('Firefox') -eq $False) { start firefox }
# alt + shift + return    : if ($wshell.AppActivate('Edge') -eq $False) { start msedge }
alt + shift + return    : start msedge
alt + return            : start wt
# alt + b               : if ($wshell.AppActivate('Chrome') -eq $False) { start chrome }

alt + q                 : komorebic close
alt + m                 : komorebic minimize
alt + shift + m         : $s = komorebic.exe state | ConvertFrom-Json; $ws = $s.monitors.elements[$s.monitors.focused].workspaces; $c = $ws.elements[$ws.focused].containers; if ($c.elements.Count -gt 1) { 1..($c.elements.Count - 1) | ForEach-Object { komorebic.exe cycle-focus next; komorebic.exe minimize } }

# used by neovim quickfix
# alt + h                 : komorebic focus left
# alt + l                 : komorebic focus right

# alt + j                 : komorebic focus down
# alt + k                 : komorebic focus up
alt + p                 : komorebic cycle-focus previous # oem_4 is [
alt + n                 : komorebic cycle-focus next # oem_6 is ]
alt + shift + p         : komorebic cycle-move previous
alt + shift + n         : komorebic cycle-move next

# Move windows
alt + shift + h         : komorebic move left
alt + shift + j         : komorebic move down
alt + shift + k         : komorebic move up
alt + shift + l         : komorebic move right
alt + space             : komorebic promote

# Stack windows
alt + shift + left      : komorebic stack left
alt + shift + down      : komorebic stack down
alt + shift + up        : komorebic stack up
alt + shift + right     : komorebic stack right
alt + oem_1             : komorebic unstack # oem_1 is ;
alt + oem_4             : komorebic cycle-stack previous # oem_4 is [
alt + oem_6             : komorebic cycle-stack next # oem_6 is ]

# Resize
alt + oem_plus          : komorebic resize-axis horizontal increase
alt + oem_minus         : komorebic resize-axis horizontal decrease
alt + shift + oem_plus  : komorebic resize-axis vertical increase
alt + shift + oem_minus : komorebic resize-axis vertical decrease

# Manipulate windows
alt + t                 : komorebic toggle-float
alt + f                 : komorebic toggle-monocle
alt + shift + f         : komorebic toggle-maximize

# Window manager options
alt + shift + t         : komorebic retile
alt + shift + r         : komorebic stop --whkd --bar; komorebic start --whkd --bar
alt + s                 : komorebic toggle-pause

# Layouts
alt + x                 : komorebic flip-layout horizontal
alt + y                 : komorebic flip-layout vertical

# Focus container by index on current workspace
alt + 1                 : $s = komorebic.exe state | ConvertFrom-Json; $m = $s.monitors.elements[$s.monitors.focused]; $w = $m.workspaces.elements[$m.workspaces.focused]; $target = 0; $current = $w.containers.focused; $count = $w.containers.elements.Count; if ($target -lt $count -and $target -ne $current) { $diff = (($target - $current + $count) % $count); 1..$diff | ForEach-Object { komorebic.exe cycle-focus next } }
