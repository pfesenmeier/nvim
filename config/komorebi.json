{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.41/schema.json",
  "app_specific_configuration_path": "$Env:USERPROFILE/applications.json",
  "default_container_padding": 15,
  "default_workspace_padding": 15,
  "stackbar": {
    "label": "Title",
    "mode": "OnStack",
    "height": 25,
    "tabs": {
      "font_size": 20,
      "font_family": "0xProto Nerd Font Mono"
    }
  },
  "bar_configurations": [
    "$Env:USERPROFILE/nvim/komorebi.bar.json"
  ],
  "animation": {
    "enabled": true,
    "style": "EaseOutExpo",
    "fps": 120
  },
  "window_hiding_behaviour": "Cloak",
  "cross_monitor_move_behaviour": "Insert",
  "border": true,
  "border_width": 7,
  "border_offset": -1,
  "border_style": "Rounded",
  "theme": {
    "palette": "Base16",
    "name": "EverforestDarkHard",
    "unfocused_border": "Base02",
    "monocle_border": "Base09",
    "bar_accent": "Base0A"
  },
  "layout_defaults": {
    "Scrolling": {
      "columns": 2
    }
  },
  "manage_rules": [
    {
      "kind": "Title",
      "id": "Claude",
      "matching_strategy": "Equals"
    }
  ],
  "monitors": [
    {
      "workspaces": [
        {
          "name": "Dev",
          "layout": "BSP"
        }
      ]
    }
  ]
}
